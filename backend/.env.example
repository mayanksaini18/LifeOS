PORT=5000

# --- Database ---
# NOTE: rotate the previously hardcoded Atlas credential and put the new URI here only.
MONGO_URI=mongodb+srv://<username>:<password>@<cluster>.mongodb.net/<dbname>

# --- Auth / JWT ---
ACCESS_TOKEN_SECRET=generate_a_strong_random_secret_min_32_chars
REFRESH_TOKEN_SECRET=generate_another_strong_random_secret_min_32_chars

# Must be exactly "production" in deployment so cross-site auth cookies are
# Secure + SameSite=None (otherwise the session can silently drop).
NODE_ENV=development

# --- Firebase Admin (Google + phone sign-in token verification) ---
# MUST equal the frontend's NEXT_PUBLIC_FIREBASE_PROJECT_ID, or verifyIdToken
# rejects every Google/phone token with a generic 401.
FIREBASE_PROJECT_ID=lifeos-f9dc4

# --- Email (Resend) — required for signup verification emails ---
# Without RESEND_API_KEY, /auth/register creates the user then 502s, stranding
# the account (can never verify -> can never log in).
RESEND_API_KEY=your_resend_api_key
RESEND_FROM=LifeOS <no-reply@yourdomain.com>

# Base URL used to build verification links in emails.
APP_URL=http://localhost:3000

# --- AI (chat / insights) ---
ANTHROPIC_API_KEY=your_anthropic_api_key
ANTHROPIC_MODEL=claude-sonnet-5

# --- Web Push (generate once with: node -e "const wp=require('web-push'); const k=wp.generateVAPIDKeys(); console.log(k)") ---
VAPID_PUBLIC_KEY=your_vapid_public_key
VAPID_PRIVATE_KEY=your_vapid_private_key
VAPID_SUBJECT=mailto:admin@yourdomain.com
